{
  "expo": {
    "name": "SafetyFirst",
    "slug": "safety-first",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "safetyfirst",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safetyfirst.app"
    },
    "android": {
      "package": "com.safetyfirst.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SafetyFirst to access your camera to capture emergency photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
